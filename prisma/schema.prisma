// 전자결재 시스템 데이터 모델
// PostgreSQL 사용 (SQLite는 enum을 지원하지 않아 배포 시 에러가 났었죠 - 이제 로컬/배포 모두 Postgres로 통일합니다)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Permission {
  ADMIN // 모든 기능
  MANAGER // 관리자: 권한 부여, 공지사항 작성
  USER // 기본값
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  username  String     @unique // 로그인 아이디
  password  String // bcrypt 해시
  role      String // 예: 팀장, 부서장, 대표, 사원 (직급)
  permission Permission @default(USER) // 사용자 / 관리자 / admin
  createdAt DateTime   @default(now())

  requestedDocuments Document[]     @relation("Requester")
  approvalSteps      ApprovalStep[]
  notices            Notice[]
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

enum DocumentStatus {
  PENDING // 결재 진행중
  APPROVED // 최종 승인 완료
  REJECTED // 반려됨
}

model Document {
  id          String         @id @default(cuid())
  title       String
  type        String // 예: 휴가, 지출결의, 구매요청, 재택근무
  content     String
  status      DocumentStatus @default(PENDING)
  requesterId String
  requester   User           @relation("Requester", fields: [requesterId], references: [id])
  steps       ApprovalStep[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

enum StepStatus {
  WAITING // 아직 내 차례가 아님
  PENDING // 지금 내가 결재해야 함
  APPROVED
  REJECTED
}

model ApprovalStep {
  id         String     @id @default(cuid())
  documentId String
  document   Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  approverId String
  approver   User       @relation(fields: [approverId], references: [id])
  order      Int // 결재 순서 (1부터 시작)
  status     StepStatus @default(WAITING)
  comment    String?
  decidedAt  DateTime?

  @@unique([documentId, order])
}
